# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem      1.0

name            control-flow
version         1.0
categories      test
license         BSD
platforms       darwin
supported_archs noarch

if {${os.major} >= 20} {
    depends_lib-append      port:modern-lib
} else {
    depends_lib-append      port:legacy-lib
}

foreach lang {python ruby perl} {
    depends_run-append      port:${lang}
}

platform darwin {
    depends_build-append    port:xcode-tools
}

variant mysql description "MySQL support" {
    if {${os.major} >= 18} {
        depends_lib-append  port:mysql8
    } else {
        depends_lib-append  port:mysql57
    }
}
